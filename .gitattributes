# Auto-detect text files
* text=auto

# Force LF line endings for cross-platform consistency
*.py    text eol=lf
*.sh    text eol=lf
*.tcss  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.j2    text eol=lf
Makefile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.zip binary
